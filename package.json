{
  "name": "qrmeet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "gen:wrangler": "node scripts/gen-wrangler.mjs",
    "db:migrate": "wrangler d1 migrations apply qrmeet-db",
    "simulate": "tsx scripts/simulate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run --project frontend",
    "test:workers": "vitest run --project workers",
    "pretest:e2e": "wrangler d1 migrations apply qrmeet-db --local",
    "test:e2e": "playwright test",
    "release": "release-it"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "nanoid": "^5.0.7",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@playwright/test": "^1.61.1",
    "@release-it/keep-a-changelog": "^7.1.0",
    "happy-dom": "^20.10.6",
    "release-it": "^20.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.95.0"
  }
}
