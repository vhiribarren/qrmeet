{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types"],
    "noEmit": true,
    // @simplewebauthn/server's transitive dep (@peculiar/x509) ships .d.ts
    // written against DOM WebCrypto typings absent from workers-types.
    "skipLibCheck": true
  },
  "include": ["worker/**/*.ts"]
}
