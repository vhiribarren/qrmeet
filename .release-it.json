{
  "hooks": {
    "before:init": ["npm test", "npm run test:e2e"]
  },
  "git": {
    "commitMessage": "release: update to v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release ${version}",
    "requireBranch": "main"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md",
      "addUnreleased": true,
      "strictLatest": false
    }
  }
}
